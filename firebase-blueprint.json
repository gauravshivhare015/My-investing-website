{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (deposit or withdrawal)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "deposit": { "type": "number" },
        "withdrawal": { "type": "number" }
      }
    },
    "History": {
      "title": "History",
      "description": "Portfolio value history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "marketValue": { "type": "number" }
      }
    },
    "Benchmark": {
      "title": "Benchmark",
      "description": "Benchmark simulation data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "price": { "type": "number" }
      }
    },
    "Prompt": {
      "title": "Prompt",
      "description": "A saved prompt or snippet",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "order": { "type": "number", "description": "Sorting order of the prompt" }
      }
    },
    "File": {
      "title": "File",
      "description": "An uploaded document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "number" },
        "data": { "type": "string" },
        "uploadedAt": { "type": "number" }
      }
    },
    "Holding": {
      "title": "Holding",
      "description": "A stock holding",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "qty": { "type": "number" },
        "avg": { "type": "number" },
        "ltp": { "type": "number" },
        "pClose": { "type": "number" }
      }
    },
    "ApiTrade": {
      "title": "ApiTrade",
      "description": "A trade fetched via Angel One API",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tradingsymbol": { "type": "string" },
        "transactiontype": { "type": "string" },
        "exchange": { "type": "string" },
        "quantity": { "type": "string" },
        "averageprice": { "type": "string" },
        "fillqty": { "type": "string" },
        "fillprice": { "type": "string" },
        "filltime": { "type": "string" },
        "updatetime": { "type": "string" },
        "syncedAt": { "type": "number" }
      }
    },
    "ApiFund": {
      "title": "ApiFund",
      "description": "User funds status from API",
      "type": "object",
      "properties": {
        "availablecash": { "type": "string" },
        "payin": { "type": "string" },
        "payout": { "type": "string" },
        "net": { "type": "string" },
        "syncedAt": { "type": "number" }
      }
    },
    "ApiFundHistory": {
      "title": "ApiFundHistory",
      "description": "Historical fund status from API",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "availablecash": { "type": "string" },
        "payin": { "type": "string" },
        "payout": { "type": "string" },
        "net": { "type": "string" },
        "syncedAt": { "type": "number" }
      }
    },
    "ApiSummary": {
      "title": "ApiSummary",
      "description": "Portfolio summary from API (e.g. SGB, total value)",
      "type": "object",
      "properties": {
        "totalholdingvalue": { "type": "number" },
        "totalinvvalue": { "type": "number" },
        "updatedAt": { "type": "string" }
      }
    },
    "BenchmarkHistoricalChunk": {
      "title": "BenchmarkHistoricalChunk",
      "description": "A chunk of historical benchmark data",
      "type": "object",
      "properties": {
        "data": { "type": "array" },
        "updatedAt": { "type": "number" }
      }
    },
    "ManualBenchmark": {
      "title": "ManualBenchmark",
      "description": "Manual override for benchmark price",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "price": { "type": "number" }
      }
    },
    "BrokerSettings": {
      "title": "BrokerSettings",
      "description": "User credentials for various brokers",
      "type": "object",
      "properties": {
        "brokerId": { "type": "string", "enum": ["angelone"] },
        "credentials": { "type": "object" },
        "updatedAt": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/artifacts/{appId}/users/{userId}/broker_settings/{brokerId}": {
      "schema": { "$ref": "#/entities/BrokerSettings" },
      "description": "User credentials for specific broker"
    },
    "/artifacts/{appId}/users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "User transactions"
    },
    "/artifacts/{appId}/users/{userId}/history/{historyId}": {
      "schema": { "$ref": "#/entities/History" },
      "description": "User portfolio history"
    },
    "/artifacts/{appId}/users/{userId}/benchmark/{benchmarkId}": {
      "schema": { "$ref": "#/entities/Benchmark" },
      "description": "User benchmark data"
    },
    "/artifacts/{appId}/users/{userId}/prompts/{promptId}": {
      "schema": { "$ref": "#/entities/Prompt" },
      "description": "User saved prompts"
    },
    "/artifacts/{appId}/users/{userId}/files/{fileId}": {
      "schema": { "$ref": "#/entities/File" },
      "description": "User uploaded files"
    },
    "/artifacts/{appId}/users/{userId}/holdings/{holdingId}": {
      "schema": { "$ref": "#/entities/Holding" },
      "description": "User stock holdings"
    },
    "/artifacts/{appId}/users/{userId}/api_trades/{tradeId}": {
      "schema": { "$ref": "#/entities/ApiTrade" },
      "description": "User trades from API"
    },
    "/artifacts/{appId}/users/{userId}/api_funds/{fundId}": {
      "schema": { "$ref": "#/entities/ApiFund" },
      "description": "User funds from API"
    },
    "/artifacts/{appId}/users/{userId}/api_fund_history/{historyId}": {
      "schema": { "$ref": "#/entities/ApiFundHistory" },
      "description": "User funds history from API"
    },
    "/artifacts/{appId}/users/{userId}/api_summary/{summaryId}": {
      "schema": { "$ref": "#/entities/ApiSummary" },
      "description": "User portfolio summary from API"
    },
    "/artifacts/{appId}/users/{userId}/benchmark_historical/{chunkId}": {
      "schema": { "$ref": "#/entities/BenchmarkHistoricalChunk" },
      "description": "Chunks of historical benchmark data"
    },
    "/artifacts/{appId}/users/{userId}/manual_benchmark/{dateId}": {
      "schema": { "$ref": "#/entities/ManualBenchmark" },
      "description": "Manual benchmark price overrides"
    }
  }
}
