{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (deposit or withdrawal)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "deposit": { "type": "number" },
        "withdrawal": { "type": "number" }
      }
    },
    "History": {
      "title": "History",
      "description": "Portfolio value history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "marketValue": { "type": "number" }
      }
    },
    "Benchmark": {
      "title": "Benchmark",
      "description": "Benchmark simulation data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "price": { "type": "number" }
      }
    },
    "Prompt": {
      "title": "Prompt",
      "description": "A saved prompt or snippet",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" }
      }
    },
    "File": {
      "title": "File",
      "description": "An uploaded document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "number" },
        "data": { "type": "string" },
        "uploadedAt": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/artifacts/{appId}/users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "User transactions"
    },
    "/artifacts/{appId}/users/{userId}/history/{historyId}": {
      "schema": { "$ref": "#/entities/History" },
      "description": "User portfolio history"
    },
    "/artifacts/{appId}/users/{userId}/benchmark/{benchmarkId}": {
      "schema": { "$ref": "#/entities/Benchmark" },
      "description": "User benchmark data"
    },
    "/artifacts/{appId}/users/{userId}/prompts/{promptId}": {
      "schema": { "$ref": "#/entities/Prompt" },
      "description": "User saved prompts"
    },
    "/artifacts/{appId}/users/{userId}/files/{fileId}": {
      "schema": { "$ref": "#/entities/File" },
      "description": "User uploaded files"
    }
  }
}
