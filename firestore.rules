rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Phase 0: Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /artifacts/{appId}/users/{userId} {
      // Allow the user document itself
      allow read, write: if isOwner(userId);

      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId);
      }
      match /history/{historyId} {
        allow read, write: if isOwner(userId);
      }
      match /benchmark/{benchmarkId} {
        allow read, write: if isOwner(userId);
      }
      match /prompts/{promptId} {
        allow read, write: if isOwner(userId);
      }
      match /files/{fileId} {
        allow read, write: if isOwner(userId);
      }
      match /holdings/{holdingId} {
        allow read, write: if isOwner(userId);
      }
      match /api_trades/{tradeId} {
        allow read, write: if isOwner(userId);
      }
      match /api_funds/{fundId} {
        allow read, write: if isOwner(userId);
      }
      match /api_fund_history/{historyId} {
        allow read, write: if isOwner(userId);
      }
      match /api_summary/{summaryId} {
        allow read, write: if isOwner(userId);
      }
      match /broker_settings/{brokerId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
